{% doc %}
  Renders a full-screen overlay for child product links from a menu.
  @param {linklist} menu - Primary menu object with top-level items and child links
{% enddoc %}

{%- if menu != blank -%}
  <div class="section__menu-items-overlay menu-items-overlay" hidden aria-hidden="true">
    <button
      class="menu-items-overlay__backdrop"
      type="button"
      aria-label="{{ 'accessibility.close' | t }}"
    ></button>
    <div class="menu-items-overlay__content" role="dialog" aria-modal="true" aria-label="Menu products">
      {%- for parent_link in menu.links -%}
        {%- assign has_product_children = false -%}
        {%- for child_link in parent_link.links -%}
          {%- if child_link.type == 'product_link' and child_link.object != blank -%}
            {%- assign has_product_children = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if has_product_children -%}
          <div class="menu-items-overlay__panel" hidden>
            <div class="menu-items-overlay__grid">
              {%- for child_link in parent_link.links -%}
                {%- if child_link.type == 'product_link' and child_link.object != blank -%}
                  {%- assign product = child_link.object -%}
                  {%- assign selected_variant = product.selected_or_first_available_variant -%}
                  {%- assign card_image = product.featured_image -%}
                  {%- if product.metafields.custom.large_product_card_image != blank -%}
                    {%- assign card_image = product.metafields.custom.large_product_card_image.value -%}
                  {%- endif -%}
                  {%- assign product_not_available_yet = product.metafields.custom.product_not_available_yet.value -%}
                  <article class="menu-items-overlay__product-card{% if product_not_available_yet %} product-nay{% endif %}">
                    <a class="menu-items-overlay__product-image-link" href="{{ product.url }}">
                      {%- if card_image != blank -%}
                        {{
                          card_image
                          | image_url: width: 960
                          | image_tag: loading: 'lazy', class: 'menu-items-overlay__product-image', alt: product.title
                        }}
                      {%- endif -%}
                    </a>
                    <div class="menu-items-overlay__product-meta">

                    {% comment %} Product tags {% endcomment %}
                        {%- assign product_tag_callouts = product.metafields.custom.product_tag_callouts.value -%}
                        <div class="card__tag-callouts">
                        
                            {% if product_tag_callouts != blank %}
                            {% for tag_callout in product_tag_callouts %}
                            <span class="product-card__tag">{{ tag_callout }}</span>
                            {% endfor %}
                            {% endif %}
                        
                            {%- assign available_count = product.selected_or_first_available_variant.inventory_quantity | default: 0 -%}
                            <span class="product-card__tag stock-amount">
                                {% if available_count > 0 %}
                                {{ available_count }} available
                                {% else %}
                                Sold out
                                {% endif %}
                            </span>
                        
                        </div>
                    {% comment %} End Product tags {% endcomment %}
                    
                    <div class="title__price-wrap">
                      <a class="menu-items-overlay__product-title fh3" href="{{ product.url }}">
                        {{- product.title | escape -}}
                      </a>
                      <p class="menu-items-overlay__price">{{ product.price | money }}</p>
                    </div>
                      
                      {%- if selected_variant != blank -%}
                        {%- form 'product', product, class: 'menu-items-overlay__form' -%}
                          <input type="hidden" name="id" value="{{ selected_variant.id }}">
                          <button type="submit" name="add" class="menu-items-overlay__buy-button button button--primary">
                            {{ 'products.product.add_to_cart' | t }}
                          </button>
                        {%- endform -%}
                      {%- endif -%}
                    </div>
                  </article>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% javascript %}
  (() => {
    const overlay = document.querySelector('.section__menu-items-overlay');
    if (!overlay) return;

    const nav = document.querySelector('.phil-primary-nav-plain');
    if (!nav) return;

    const triggers = nav.querySelectorAll('.phil-nav__link--overlay-trigger');
    const panels = overlay.querySelectorAll('.menu-items-overlay__panel');
    const backdrop = overlay.querySelector('.menu-items-overlay__backdrop');

    if (!triggers.length || !panels.length || !backdrop) return;

    let activePanelIndex = -1;
    let timeline = null;

    function cleanupInlineStyles() {
      backdrop.style.removeProperty('opacity');
      panels.forEach((panel) => {
        const cards = panel.querySelectorAll('.menu-items-overlay__product-card');
        cards.forEach((card) => {
          card.style.removeProperty('opacity');
          card.style.removeProperty('transform');
        });
      });
    }

    function hideAllPanels() {
      panels.forEach((panel) => {
        panel.hidden = true;
      });
    }

    function hideOverlay() {
      overlay.hidden = true;
      overlay.setAttribute('aria-hidden', 'true');
      hideAllPanels();
      cleanupInlineStyles();
      activePanelIndex = -1;
      if (timeline) {
        timeline.kill();
        timeline = null;
      }
    }

    function buildTimeline(panelIndex) {
      if (typeof gsap === 'undefined') return null;
      const panel = panels[panelIndex];
      if (!panel) return null;

      const cards = panel.querySelectorAll('.menu-items-overlay__product-card');
      const tl = gsap.timeline({
        defaults: { ease: 'power2.out' },
        onReverseComplete: hideOverlay
      });

      tl.set(backdrop, { opacity: 0 });
      tl.to(backdrop, { opacity: 1, duration: 0.25 });
      tl.fromTo(
        cards,
        { opacity: 0, y: 24 },
        { opacity: 1, y: 0, duration: 0.45, stagger: 0.3 },
        '-=0.05'
      );
      return tl;
    }

    function showPanelByIndex(panelIndex) {
      hideAllPanels();
      const panel = panels[panelIndex];
      if (!panel) return false;
      panel.hidden = false;
      activePanelIndex = panelIndex;
      return true;
    }

    function openMenu(panelIndex) {
      if (!showPanelByIndex(panelIndex)) return;

      overlay.hidden = false;
      overlay.setAttribute('aria-hidden', 'false');

      if (timeline) {
        timeline.kill();
        timeline = null;
      }

      cleanupInlineStyles();

      timeline = buildTimeline(panelIndex);
      if (!timeline) {
        backdrop.style.opacity = '1';
        return;
      }

      timeline.play(0);
    }

    function closeMenu() {
      if (overlay.hidden) return;
      if (!timeline) {
        hideOverlay();
        return;
      }
      timeline.reverse();
    }

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', (event) => {
        if (!panels[index]) return;

        event.preventDefault();
        if (!overlay.hidden && activePanelIndex === index) {
          return;
        }
        openMenu(index);
      });
    });

    backdrop.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenu();
    });
  })();
{% endjavascript %}