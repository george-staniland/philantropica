{% doc %}
  Renders a full-screen overlay for child product links from a menu.
  @param {linklist} menu - Primary menu object with top-level items and child links
{% enddoc %}

{%- if menu != blank -%}
  <div class="section__menu-items-overlay menu-items-overlay" data-menu-overlay-root hidden aria-hidden="true">
    <button
      class="menu-items-overlay__backdrop"
      type="button"
      aria-label="{{ 'accessibility.close' | t }}"
      data-menu-overlay-close
    ></button>
    <div class="menu-items-overlay__content" role="dialog" aria-modal="true" aria-label="Menu products">
      {%- for parent_link in menu.links -%}
        {%- assign has_product_children = false -%}
        {%- for child_link in parent_link.links -%}
          {%- if child_link.type == 'product_link' and child_link.object != blank -%}
            {%- assign has_product_children = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if has_product_children -%}
          <div class="menu-items-overlay__panel" data-menu-overlay-panel="{{ forloop.index0 }}" hidden>
            <div class="menu-items-overlay__grid">
              {%- for child_link in parent_link.links -%}
                {%- if child_link.type == 'product_link' and child_link.object != blank -%}
                  {%- assign product = child_link.object -%}
                  {%- assign selected_variant = product.selected_or_first_available_variant -%}
                  <article class="menu-items-overlay__product-card">
                    <a class="menu-items-overlay__product-image-link" href="{{ product.url }}">
                      {%- if product.featured_image != blank -%}
                        {{
                          product.featured_image
                          | image_url: width: 960
                          | image_tag: loading: 'lazy', class: 'menu-items-overlay__product-image', alt: product.title
                        }}
                      {%- endif -%}
                    </a>
                    <div class="menu-items-overlay__product-meta">
                      <a class="menu-items-overlay__product-title fh3" href="{{ product.url }}">
                        {{- product.title | escape -}}
                      </a>
                      <p class="menu-items-overlay__price">{{ product.price | money }}</p>
                      {%- if selected_variant != blank -%}
                        {%- form 'product', product, class: 'menu-items-overlay__form' -%}
                          <input type="hidden" name="id" value="{{ selected_variant.id }}">
                          <button type="submit" name="add" class="menu-items-overlay__buy-button button button--primary">
                            {{ 'products.product.add_to_cart' | t }}
                          </button>
                        {%- endform -%}
                      {%- endif -%}
                    </div>
                  </article>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% javascript %}
  (() => {
    const root = document.querySelector('[data-menu-overlay-root]');
    if (!root || root.dataset.overlayInit === 'true') return;
    root.dataset.overlayInit = 'true';

    const nav = root.closest('.phil-primary-nav-plain');
    if (!nav) return;

    const triggers = nav.querySelectorAll('[data-menu-overlay-trigger]');
    const closeButton = root.querySelector('[data-menu-overlay-close]');
    const backdrop = root.querySelector('.menu-items-overlay__backdrop');
    const panels = root.querySelectorAll('[data-menu-overlay-panel]');

    let activePanel = null;
    let overlayTimeline = null;

    const hideOverlay = () => {
      root.hidden = true;
      root.setAttribute('aria-hidden', 'true');
      panels.forEach((panel) => {
        panel.hidden = true;
      });

      if (overlayTimeline) {
        overlayTimeline.kill();
        overlayTimeline = null;
      }

      if (backdrop) backdrop.style.removeProperty('opacity');
      if (activePanel) {
        activePanel.querySelectorAll('.menu-items-overlay__product-card').forEach((card) => {
          card.style.removeProperty('opacity');
          card.style.removeProperty('transform');
        });
      }
      activePanel = null;
    };

    const showPanel = (panelIndex) => {
      let foundPanel = null;

      panels.forEach((panel) => {
        if (panel.dataset.menuOverlayPanel === panelIndex) {
          panel.hidden = false;
          foundPanel = panel;
        } else {
          panel.hidden = true;
        }
      });

      activePanel = foundPanel;
      return activePanel;
    };

    const playOpenAnimation = () => {
      if (!activePanel) return;

      const cards = activePanel.querySelectorAll('.menu-items-overlay__product-card');

      if (overlayTimeline) overlayTimeline.kill();

      overlayTimeline = gsap.timeline({
        paused: true,
        defaults: { ease: 'power2.out' },
        onReverseComplete: hideOverlay
      });

      if (backdrop) {
        overlayTimeline.set(backdrop, { opacity: 0 });
        overlayTimeline.to(backdrop, { opacity: 1, duration: 0.25 });
      }

      overlayTimeline.fromTo(
        cards,
        { opacity: 0, y: 24 },
        { opacity: 1, y: 0, duration: 0.45, stagger: 0.3 },
        backdrop ? '-=0.05' : 0
      );

      overlayTimeline.play(0);
    };

    const openOverlay = (panelIndex) => {
      if (!showPanel(panelIndex)) return;

      root.hidden = false;
      root.setAttribute('aria-hidden', 'false');

      if (typeof gsap === 'undefined') return;
      playOpenAnimation();
    };

    const closeOverlay = () => {
      if (root.hidden) return;

      if (typeof gsap === 'undefined' || !overlayTimeline) {
        hideOverlay();
        return;
      }

      overlayTimeline.reverse();
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        const panelIndex = trigger.dataset.menuOverlayParentIndex;
        if (!panelIndex) return;

        const hasPanel = Array.from(panels).some((panel) => panel.dataset.menuOverlayPanel === panelIndex);
        if (!hasPanel) return;

        event.preventDefault();
        openOverlay(panelIndex);
      });
    });

    if (closeButton) {
      closeButton.addEventListener('click', closeOverlay);
    }

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeOverlay();
    });
  })();
{% endjavascript %}